# ILL CTS backend environment — copy to .env and fill in
DATABASE_URL="postgresql://USER@localhost:5432/ill_cts?schema=public"
PORT=5002
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"
CORS_ORIGIN="http://localhost:3007"
# Default fiscal cutoff (Indian FY boundary). New = on/after this date.
CUTOFF_DATE="2026-04-01"
